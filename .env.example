# Database
DB_PATH=./data/bookmark-kb.db

# Raw content archive
ARCHIVE_PATH=./data/raw

# Obsidian vault output
VAULT_PATH=./vault

# llama.cpp server
LLM_SERVER_URL=http://localhost:8080

# Twitter/X
TWITTER_COOKIES_PATH=./cookies/twitter-cookies.json

# YouTube
YOUTUBE_COOKIES_PATH=./cookies/youtube-cookies.txt

# GitHub
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Raindrop
RAINDROP_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Reddit — single account
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USERNAME=your_username
REDDIT_PASSWORD=your_password

# Reddit — multiple accounts (overrides the single-account vars above)
# REDDIT_ACCOUNTS='[{"clientId":"id1","clientSecret":"secret1","username":"user1","password":"pass1"},{"clientId":"id2","clientSecret":"secret2","username":"user2","password":"pass2"}]'

# Media storage
MEDIA_PATH=./data/media
# MEDIA_MAX_IMAGE_SIZE_MB=10
# MEDIA_MAX_VIDEO_SIZE_MB=500

# Multi-provider LLM (for step 2 type-specific classification)
# Comma-separated, tried in order. Options: local, openrouter, groq, nvidia, gemini
# LLM_STEP2_PROVIDERS=openrouter,groq,local
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=google/gemma-3-27b-it:free
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile
# NVIDIA_API_KEY=nvapi-...
# NVIDIA_MODEL=meta/llama-3.1-8b-instruct
# GEMINI_MODEL=gemini-2.5-flash-lite  # uses gemini-cli (no API key needed, authenticated via gcloud)

# Whisper (for audio/video transcription)
# Models: tiny, base, small, medium, large
WHISPER_MODEL=base

# Discord
DISCORD_BOT_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DISCORD_CHANNEL_ID=000000000000000000

# Logging
LOG_LEVEL=info
